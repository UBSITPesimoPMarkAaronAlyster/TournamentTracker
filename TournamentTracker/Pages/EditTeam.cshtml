@page "{id:int}"
@model TournamentTracker.Pages.EditTeamModel
@{
    ViewData["Title"] = "Edit Team";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h2 class="mb-0">Edit Team</h2>
    </div>

    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Team.TeamId" />

            <div class="mb-3">
                <label class="form-label">Team Name</label>
                <input asp-for="Team.TeamName" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Tournament</label>
                <select asp-for="Team.TournamentId" class="form-select" required>
                    @foreach (var tournament in Model.TournamentList)
                    {
                        <option value="@tournament.TournamentId">
                            @tournament.TournamentName
                        </option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-warning">
                Update Team
            </button>

            <a href="/Teams" class="btn btn-secondary">
                Back
            </a>
        </form>
    </div>
</div>