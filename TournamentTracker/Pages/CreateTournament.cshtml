@page
@model TournamentTracker.Pages.CreateTournamentModel
@{
    ViewData["Title"] = "Create Tournament";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h2 class="mb-0">Create Tournament</h2>
    </div>

    <div class="card-body">

        <form method="post">

            <div class="mb-3">
                <label class="form-label">
                    Tournament Name
                </label>

                <input asp-for="Tournament.TournamentName"
                       class="form-control"
                       required />
            </div>


            <div class="mb-3">
                <label class="form-label">
                    Start Date
                </label>

                <input asp-for="Tournament.StartDate"
                       type="date"
                       class="form-control"
                       required />
            </div>


            <div class="mb-3">
                <label class="form-label">
                    Status
                </label>

                <select asp-for="Tournament.Status"
                        class="form-select">

                    <option value="Upcoming">
                        Upcoming
                    </option>

                    <option value="Ongoing">
                        Ongoing
                    </option>

                    <option value="Finished">
                        Finished
                    </option>

                </select>
            </div>


            <div class="mb-4">
                <label class="form-label">
                    Bracket Size
                </label>

                <select asp-for="Tournament.BracketSize"
                        class="form-select"
                        required>

                    <option value="4">
                        4 Teams
                    </option>

                    <option value="8">
                        8 Teams
                    </option>

                    <option value="16">
                        16 Teams
                    </option>

                </select>
            </div>


            <button type="submit"
                    class="btn btn-primary">
                Create Tournament
            </button>

            <a href="/Tournament"
               class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>
</div>