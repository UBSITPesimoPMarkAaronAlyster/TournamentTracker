@page
@model TournamentTracker.Pages.TournamentModel
@{
    ViewData["Title"] = "Tournaments";
}

<div class="card shadow-sm border-0">

    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0">
            Tournaments
        </h2>

        <a href="/CreateTournament"
           class="btn btn-primary">
            Add Tournament
        </a>
    </div>


    <div class="card-body">

        <table class="table table-striped table-bordered table-hover">

            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Start Date</th>
                    <th>Status</th>
                    <th>Bracket</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var tournament in Model.TournamentList)
                {
                    <tr>

                        <td>
                            @tournament.TournamentId
                        </td>

                        <td>
                            @tournament.TournamentName
                        </td>

                        <td>
                            @tournament.StartDate.ToString("yyyy-MM-dd")
                        </td>

                        <td>
                            @tournament.Status
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @tournament.BracketSize Teams
                            </span>
                        </td>

                        <td>

                            <a href="/EditTournament/@tournament.TournamentId"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a href="/DeleteTournament/@tournament.TournamentId"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>